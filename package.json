{
  "name": "saas-integracion",
  "private": true,
  "version": "1.0.0",
  "description": "Orquestación simple de frontend y backend desde raíz",
  "scripts": {
    "frontend:install": "cd saas-frontend/frontend && npm install",
    "frontend:dev": "cd saas-frontend/frontend && npm run dev",
    "frontend:build": "cd saas-frontend/frontend && npm run build",
    "frontend:lint": "cd saas-frontend/frontend && npm run lint",
    "backend:dev": "cd backend && ./gradlew bootRun",
    "backend:test": "cd backend && ./gradlew test",
    "backend:build": "cd backend && ./gradlew bootJar",
    "compose:up": "cd backend && docker compose up -d",
    "compose:down": "cd backend && docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
